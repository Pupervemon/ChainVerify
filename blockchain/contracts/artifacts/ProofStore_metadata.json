		"devdoc": {
			"details": "链上存证智能合约，用于将文件哈希和 IPFS CID 绑定并持久化记录在区块链上。",
			"kind": "dev",
			"methods": {
				"getProof(string)": {
					"details": "根据文件哈希查询单条存证记录详情",
					"params": {
						"_fileHash": "文件哈希"
					},
					"returns": {
						"_0": "Proof 对应哈希的存证详情结构信息"
					}
				},
				"getUserProofs(address)": {
					"details": "查询特定用户的存证哈希列表",
					"params": {
						"_user": "用户钱包地址"
					},
					"returns": {
						"_0": "string[] 用户所存证的文件哈希集合"
					}
				},
				"storeProof(string,string,uint256,string,string)": {
					"details": "存储新的文件存证记录",
					"params": {
						"_cid": "IPFS 上传后得到的 CID",
						"_contentType": "MIME 类型",
						"_fileHash": "文件哈希 (建议前端计算好后传入)",
						"_fileName": "文件名称",
						"_fileSize": "文件大小"
					}
				},
				"verifyProof(string,string)": {
					"details": "验证给定的文件是否由当前账号存证，并且并未被篡改 (匹配 CID)",
					"params": {
						"_cid": "要对比的 CID",
						"_fileHash": "文件哈希"
					},
					"returns": {
						"_0": "bool 验证成功与否"
					}
				}
			},
